{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the project."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the project."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Technology tags used in the project."
        },
        "link": {
          "type": "string",
          "format": "uri",
          "description": "Link to the project (e.g., GitHub)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the project was added."
        }
      },
      "required": ["title", "description", "tags"]
    },
    "User": {
      "title": "User",
      "description": "A user profile for admin access.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"]
        }
      },
      "required": ["email", "role"]
    },
    "SiteConfig": {
      "title": "Site Configuration",
      "description": "Global site settings and content.",
      "type": "object",
      "properties": {
        "introCards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "icon": { "type": "string" }
            }
          },
          "description": "Cards displayed in the intro section (e.g., Future Focus)."
        },
        "introText": {
          "type": "string",
          "description": "The short introduction text on the home page."
        },
        "jobTitle": {
          "type": "string",
          "description": "The job title displayed under the name on the home page."
        },
        "profileImage": {
          "type": "string",
          "description": "URL of the profile image."
        },
        "bio": {
          "type": "string",
          "description": "The detailed bio text in the intro section."
        },
        "profileText": {
          "type": "string",
          "description": "The text above the technical stack in the about section."
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of technical skills."
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "level": { "type": "string" }
            }
          },
          "description": "List of languages spoken."
        },
        "experiences": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "company": { "type": "string" },
              "period": { "type": "string" },
              "points": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "description": "Work experience history."
        }
      }
    }
    "Message": {
      "title": "Message",
      "description": "A contact form message.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles for role management."
    },
    "/config/{configId}": {
      "schema": "SiteConfig",
      "description": "Global site configuration."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Contact form submissions."
    }
  }
}
