rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - tags: list (required)
    //   - link: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dan.kachkyy@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'description', 'tags', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.tags is list &&
             data.createdAt is timestamp;
    }

    // Projects: Publicly readable, admin writable
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProject(request.resource.data);
    }

    // Config: Publicly readable, admin writable
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: Owner readable, admin writable (for role management)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
